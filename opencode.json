{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "assistant",
  "agent": {
    "assistant": {
      "description": "Orquestador general (deriva a agentes especializados)",
      "mode": "primary",
      "model": "openai/gpt-5.2",
      "temperature": 0.2,
      "prompt": "{file:./System Prompts/assistant.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "support": {
      "description": "Soporte de producto (diagnostico y KB)",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "temperature": 0.1,
      "prompt": "{file:./System Prompts/support.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "requirements": {
      "description": "Redactor de PRDs/especificaciones de producto",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "temperature": 0.2,
      "prompt": "{file:./System Prompts/requirements.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": false
      }
    },
    "knowledge-curator": {
      "description": "Mantenimiento del KB (normaliza y actualiza la base)",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "temperature": 0.1,
      "prompt": "{file:./System Prompts/knowledge-curator.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "performance-marketing": {
      "description": "Analisis y estrategia de performance (Meta Ads y ASA)",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "temperature": 0.2,
      "prompt": "{file:./System Prompts/performance-marketing.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "copywriter": {
      "description": "Copywriter (voz/tono de marca)",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "temperature": 0.7,
      "prompt": "{file:./System Prompts/copywriter.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "ads-scripts": {
      "description": "Guiones para anuncios (UGC, performance, brand)",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "temperature": 0.6,
      "prompt": "{file:./System Prompts/ads-scripts.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "seo": {
      "description": "SEO (analisis, estrategia, contenido y tecnico)",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "temperature": 0.2,
      "prompt": "{file:./System Prompts/seo.md}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": false
      }
    },
    "github-issues": {
      "description": "GitHub (Issues + Projects) - Gestion de tareas",
      "mode": "subagent",
      "model": "openai/gpt-5.2",
      "temperature": 0.1,
      "prompt": "{file:./System Prompts/github-issues.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "code-review": {
      "description": "Reviews code for quality and best practices",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.1,
      "prompt": "{file:./System Prompts/code-review.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "test-orchestrator": {
      "description": "Designs, runs, and interprets tests for recent changes",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:./System Prompts/test-orchestrator.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  }
}
