generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserKind {
  HUMAN
  SERVICE
}

enum ProviderCredentialStatus {
  enabled
  disabled
}

enum AutopilotRunStatus {
  running
  succeeded
  failed
}

enum AutopilotRunTrigger {
  on_create
  schedule
  manual
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  slug         String      @unique
  role         UserRole    @default(USER)
  kind         UserKind    @default(HUMAN)
  passwordHash String      @map("password_hash")
  totpEnabled    Boolean     @default(false) @map("totp_enabled")
  totpSecret     String?     @map("totp_secret")
  totpVerifiedAt DateTime?   @map("totp_verified_at")
  totpLastUsedAt DateTime?   @map("totp_last_used_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  sessions           Session[]
  auditEvents        AuditEvent[] @relation("AuditActor")
  instance           Instance?
  twoFactorRecovery  TwoFactorRecovery[]
  connectors         Connector[]
  providerCredentials ProviderCredential[]
  autopilotTasks      AutopilotTask[]
  slackThreadBindings SlackThreadBinding[]

  @@map("users")
}

model ExternalIntegration {
  key       String   @id @map("key")
  config    String   // AES-256-GCM encrypted JSON
  state     Json?    @default("{}")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("external_integrations")
}

model SlackThreadBinding {
  id               String   @id @default(cuid())
  channelId        String   @map("channel_id")
  threadTs         String   @map("thread_ts")
  openCodeSessionId String  @map("opencode_session_id")
  executionUserId  String   @map("execution_user_id")
  executionUser    User     @relation(fields: [executionUserId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([channelId, threadTs])
  @@index([executionUserId])
  @@map("slack_thread_bindings")
}

model SlackEventReceipt {
  id         String   @id @default(cuid())
  eventId    String   @unique @map("event_id")
  type       String
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([receivedAt])
  @@map("slack_event_receipts")
}

enum InstanceStatus {
  starting
  running
  stopped
  error
}

model Instance {
  id              String         @id @default(cuid())
  slug            String         @unique

  status          InstanceStatus @default(stopped)

  createdAt       DateTime       @default(now()) @map("created_at")
  startedAt       DateTime?      @map("started_at")
  stoppedAt       DateTime?      @map("stopped_at")
  lastActivityAt  DateTime?      @map("last_activity_at")

  containerId     String?        @map("container_id")
  serverPassword  String         @map("server_password")
  appliedConfigSha String?       @map("applied_config_sha")
  providerSyncHash String?       @map("provider_sync_hash")
  providerSyncedAt DateTime?     @map("provider_synced_at")

  user            User           @relation(fields: [slug], references: [slug])

  @@index([status])
  @@map("instances")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique @map("token_hash")

  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  lastSeenAt DateTime? @map("last_seen_at")

  ip        String? @map("ip")
  userAgent String? @map("user_agent")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_events")
}

model AutopilotTask {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  cronExpression String         @map("cron_expression")
  timezone       String
  prompt         String
  targetAgentId  String?        @map("target_agent_id")
  enabled        Boolean        @default(true)

  nextRunAt      DateTime       @map("next_run_at")
  lastRunAt      DateTime?      @map("last_run_at")
  leaseOwner     String?        @map("lease_owner")
  leaseExpiresAt DateTime?      @map("lease_expires_at")

  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  runs           AutopilotRun[]

  @@unique([userId, name])
  @@index([userId])
  @@index([enabled, nextRunAt])
  @@index([leaseExpiresAt])
  @@map("autopilot_tasks")
}

model AutopilotRun {
  id              String             @id @default(cuid())
  taskId          String             @map("task_id")
  task            AutopilotTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  status          AutopilotRunStatus
  trigger         AutopilotRunTrigger
  scheduledFor    DateTime           @map("scheduled_for")
  startedAt       DateTime           @default(now()) @map("started_at")
  finishedAt      DateTime?          @map("finished_at")
  error           String?
  openCodeSessionId String?          @unique @map("opencode_session_id")
  sessionTitle    String?            @map("session_title")
  resultSeenAt    DateTime?          @map("result_seen_at")

  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([taskId, startedAt])
  @@index([status])
  @@index([scheduledFor])
  @@map("autopilot_runs")
}

model Connector {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // ConnectorType from src/lib/connectors/types.ts
  name      String
  config    String   // AES-256-GCM encrypted JSON
  enabled   Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("connectors")
}

model ProviderCredential {
  id         String                   @id @default(cuid())
  userId     String                   @map("user_id")
  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String                   @map("provider_id")
  type       String
  status     ProviderCredentialStatus @default(enabled)
  version    Int
  secret     String
  lastError  String?                  @map("last_error")
  lastUsedAt DateTime?                @map("last_used_at")
  createdAt  DateTime                 @default(now()) @map("created_at")
  updatedAt  DateTime                 @updatedAt @map("updated_at")

  @@index([userId])
  @@index([providerId])
  @@map("provider_credentials")
}

model TwoFactorRecovery {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("two_factor_recovery")
}
