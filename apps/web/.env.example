DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arche?schema=public"

# Dominio base (cuando integres Traefik/subdominios). En local puedes usar `arche.lvh.me`.
ARCHE_DOMAIN="arche.lvh.me"

# Opcional. Si se define, se usa tal cual (ej: .arche.example.com). Si no, se deriva de ARCHE_DOMAIN.
ARCHE_COOKIE_DOMAIN=""

# Requerido en produccion. En desarrollo, si no se define se usa un valor inseguro.
ARCHE_SESSION_PEPPER=""

# TTL de sesion (dias)
ARCHE_SESSION_TTL_DAYS="7"

# Seed primer admin (idempotente)
ARCHE_SEED_ADMIN_EMAIL="admin@example.com"
ARCHE_SEED_ADMIN_PASSWORD="change-me"
ARCHE_SEED_ADMIN_SLUG="admin"

# === Spawner ===

# Docker: socket local (dev) o proxy (produccion)
# En macOS con Podman: /var/folders/.../podman/podman-machine-default-api.sock
# En produccion: dejar vacio y usar DOCKER_PROXY_HOST/PORT
DOCKER_SOCKET_PATH=""
DOCKER_PROXY_HOST="docker-socket-proxy"
DOCKER_PROXY_PORT="2375"

# Imagen OpenCode
OPENCODE_IMAGE="ghcr.io/anomalyco/opencode:1.1.45"

# Red Docker interna
OPENCODE_NETWORK="arche-internal"

# Encriptacion de passwords de instancias (requerido en produccion)
# Generar: openssl rand -base64 32
ARCHE_ENCRYPTION_KEY=""

# Token interno para OCPROXY
# Generar: openssl rand -base64 32
ARCHE_INTERNAL_TOKEN=""

# Tiempos de start (ms)
ARCHE_START_EXPECTED_MS="15000"
ARCHE_START_TIMEOUT_MS="120000"

# Idle reaper (minutos)
ARCHE_IDLE_TIMEOUT_MINUTES="30"
