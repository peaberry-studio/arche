# =============================================================================
# Arche Web - Environment Variables
# =============================================================================
# This file contains default values for LOCAL DEVELOPMENT.
# Copy to .env and adjust for your environment.
#
# IMPORTANT: In production, generate new values for all secret keys.
# =============================================================================

# === Database ===
# In Podman Compose: use "postgres" as host
# In local development (without Podman): use "localhost"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arche?schema=public"

# === Domain ===
# lvh.me resolves to 127.0.0.1, ideal for local development with subdomains
ARCHE_DOMAIN="arche.lvh.me"

# Optional. If set, it is used as-is (e.g. .arche.example.com)
# Otherwise it is derived from ARCHE_DOMAIN
ARCHE_COOKIE_DOMAIN=""

# === Sessions ===
# Required in production. In development, if not set an insecure value is used.
# Generar: openssl rand -base64 32
ARCHE_SESSION_PEPPER=""

# Session TTL (days)
ARCHE_SESSION_TTL_DAYS="7"

# === Gateway ===
# Required in production. Key used to sign gateway tokens.
# Generar: openssl rand -base64 32
ARCHE_GATEWAY_TOKEN_SECRET=""

# Opcional. TTL de tokens del gateway (segundos)
ARCHE_GATEWAY_TOKEN_TTL_SECONDS=""

# Opcional. Base URL del gateway (ej: https://gateway.example.com)
ARCHE_GATEWAY_BASE_URL=""

# Public base URL used for OAuth callbacks (recommended behind reverse proxies)
# Example local: http://arche.lvh.me:8080
ARCHE_PUBLIC_BASE_URL=""

# === MCP connector OAuth ===
# OAuth state encryption/signing key (required in production for connector OAuth)
# Generate: openssl rand -base64 32
ARCHE_CONNECTOR_OAUTH_STATE_SECRET=""

# OAuth state TTL (seconds)
ARCHE_CONNECTOR_OAUTH_STATE_TTL_SECONDS="600"

# MCP server URL overrides (optional)
ARCHE_CONNECTOR_LINEAR_MCP_URL="https://mcp.linear.app/mcp"
ARCHE_CONNECTOR_NOTION_MCP_URL="https://mcp.notion.com/mcp"

# Optional OAuth scope overrides
ARCHE_CONNECTOR_LINEAR_SCOPE=""
ARCHE_CONNECTOR_NOTION_SCOPE=""

# Optional static OAuth clients (fallback if dynamic client registration is unavailable)
# If omitted, Arche uses OAuth 2.1 Dynamic Client Registration automatically.
ARCHE_CONNECTOR_NOTION_CLIENT_ID=""
ARCHE_CONNECTOR_NOTION_CLIENT_SECRET=""
ARCHE_CONNECTOR_LINEAR_CLIENT_ID=""
ARCHE_CONNECTOR_LINEAR_CLIENT_SECRET=""

# Optional connector gateway settings (web-managed OAuth bridge to workspace MCP)
ARCHE_CONNECTOR_GATEWAY_BASE_URL="http://web:3000/api/internal/mcp/connectors"
ARCHE_CONNECTOR_GATEWAY_TOKEN_SECRET=""
ARCHE_CONNECTOR_GATEWAY_TOKEN_TTL_SECONDS="86400"

# === Initial admin seed (idempotent) ===
ARCHE_SEED_ADMIN_EMAIL="admin@example.com"
ARCHE_SEED_ADMIN_PASSWORD="change-me"
ARCHE_SEED_ADMIN_SLUG="admin"

# =============================================================================
# SPAWNER (Podman)
# =============================================================================
# The spawner creates containers for each user workspace.
# It can connect through a local socket or through an HTTP proxy.

# Container runtime socket - LEAVE EMPTY for Podman Compose (uses proxy)
# Only set for local development without Podman Compose:
#   macOS Podman: /var/folders/.../podman/podman-machine-default-api.sock
#   Linux rootful: /run/podman/podman.sock
CONTAINER_SOCKET_PATH=""

# Container runtime proxy (used when CONTAINER_SOCKET_PATH is empty)
# These values are correct for Podman Compose
CONTAINER_PROXY_HOST="docker-socket-proxy"
CONTAINER_PROXY_PORT="2375"

# Workspace image (OpenCode + git + init scripts)
# Build with: podman build -t arche-workspace:latest infra/workspace-image
OPENCODE_IMAGE="arche-workspace:latest"

# Internal container network (must exist or will be created automatically)
OPENCODE_NETWORK="arche-internal"

# === Encryption ===
# Key used to encrypt instance passwords (AES-256-GCM, 32 bytes base64)
# IMPORTANT: In production, generate a new key: openssl rand -base64 32
# This value is for local development only:
ARCHE_ENCRYPTION_KEY="ZGV2LW9ubHktZW5jcnlwdGlvbi1rZXktMzItYnl0ZXMh"

# Internal token for communication with OCPROXY
# Generar: openssl rand -base64 32
ARCHE_INTERNAL_TOKEN=""

# === Spawner timeouts ===
# Expected time for a workspace to start (ms) - after this, "slow start" is shown
ARCHE_START_EXPECTED_MS="15000"

# Maximum startup timeout (ms) - after this, startup is marked as error
ARCHE_START_TIMEOUT_MS="120000"

# Idle time before stopping a workspace (minutes)
ARCHE_IDLE_TIMEOUT_MINUTES="30"

# === Knowledge Base Repositories ===
# Host path to KB content bare repo (mounted into web + workspaces, required)
# deploy.sh configures this automatically as ~/.arche/kb-content
# In production: /opt/arche/kb-content
KB_CONTENT_HOST_PATH=""

# Host path to config bare repo (mounted into web, required)
# deploy.sh configures this automatically as ~/.arche/kb-config
# In production: /opt/arche/kb-config
KB_CONFIG_HOST_PATH=""

# === User Data Persistence ===
# Host path for persistent user data (MCP configs, agents)
# Default: /opt/arche/users
# For local development with deploy.sh, default: ~/.arche/users
# For development without Podman, use an absolute path like /tmp/arche-users
ARCHE_USERS_PATH="/opt/arche/users"
