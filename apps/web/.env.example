# =============================================================================
# Arche Web - Variables de Entorno
# =============================================================================
# Este fichero contiene valores por defecto para DESARROLLO LOCAL.
# Copia a .env y ajusta según tu entorno.
#
# IMPORTANTE: En producción, genera valores nuevos para todas las claves secretas.
# =============================================================================

# === Base de datos ===
# En Podman Compose: usa "postgres" como host
# En desarrollo local (sin Podman): usa "localhost"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arche?schema=public"

# === Dominio ===
# lvh.me resuelve a 127.0.0.1, ideal para desarrollo local con subdominios
ARCHE_DOMAIN="arche.lvh.me"

# Opcional. Si se define, se usa tal cual (ej: .arche.example.com)
# Si no, se deriva de ARCHE_DOMAIN
ARCHE_COOKIE_DOMAIN=""

# === Sesiones ===
# Requerido en producción. En desarrollo, si no se define se usa un valor inseguro.
# Generar: openssl rand -base64 32
ARCHE_SESSION_PEPPER=""

# TTL de sesión (días)
ARCHE_SESSION_TTL_DAYS="7"

# === Seed del admin inicial (idempotente) ===
ARCHE_SEED_ADMIN_EMAIL="admin@example.com"
ARCHE_SEED_ADMIN_PASSWORD="change-me"
ARCHE_SEED_ADMIN_SLUG="admin"

# =============================================================================
# SPAWNER (Podman)
# =============================================================================
# El spawner crea contenedores para cada workspace de usuario.
# Puede conectarse via socket local o via proxy HTTP.

# Socket del container runtime - DEJAR VACÍO para Podman Compose (usa el proxy)
# Solo definir para desarrollo local sin Podman Compose:
#   macOS Podman: /var/folders/.../podman/podman-machine-default-api.sock
#   Linux rootful: /run/podman/podman.sock
CONTAINER_SOCKET_PATH=""

# Proxy del container runtime (usado cuando CONTAINER_SOCKET_PATH está vacío)
# Estos valores son los correctos para Podman Compose
CONTAINER_PROXY_HOST="docker-socket-proxy"
CONTAINER_PROXY_PORT="2375"

# Imagen de workspace (OpenCode + git + scripts de init)
# Construir con: podman build -t arche-workspace:latest infra/workspace-image
OPENCODE_IMAGE="arche-workspace:latest"

# Red interna de contenedores (debe existir o se crea automáticamente)
OPENCODE_NETWORK="arche-internal"

# === Encriptación ===
# Clave para encriptar passwords de instancias (AES-256-GCM, 32 bytes en base64)
# IMPORTANTE: En producción, generar una clave nueva: openssl rand -base64 32
# Este valor es solo para desarrollo local:
ARCHE_ENCRYPTION_KEY="ZGV2LW9ubHktZW5jcnlwdGlvbi1rZXktMzItYnl0ZXMh"

# Token interno para comunicación con OCPROXY
# Generar: openssl rand -base64 32
ARCHE_INTERNAL_TOKEN=""

# === Timeouts del spawner ===
# Tiempo esperado para que un workspace arranque (ms) - después de esto se muestra "slow start"
ARCHE_START_EXPECTED_MS="15000"

# Timeout máximo para arranque (ms) - después de esto se marca como error
ARCHE_START_TIMEOUT_MS="120000"

# Tiempo de inactividad antes de parar un workspace (minutos)
ARCHE_IDLE_TIMEOUT_MINUTES="30"

# === Knowledge Base ===
# Path en el host donde está el KB (para montar en los workspaces)
# deploy.sh --local-dev configura esto automáticamente a ~/.arche/kb
# En producción: /opt/arche/kb
KB_HOST_PATH=""

# === User Data Persistence ===
# Path en el host para datos persistentes de usuario (MCP configs, agents)
# Default: /opt/arche/users
# Para desarrollo local con Podman Compose, usa /tmp/arche-users (ya configurado en compose.yaml)
# Para desarrollo sin Podman, usa una ruta absoluta como /tmp/arche-users
ARCHE_USERS_PATH="/opt/arche/users"
