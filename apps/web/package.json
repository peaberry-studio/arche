{
  "name": "@arche/web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "postinstall": "pnpm prisma:generate && pnpm prisma:generate:desktop",
    "predev": "pnpm prisma:generate && pnpm prisma:generate:desktop",
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "prebuild": "pnpm prisma:generate && pnpm prisma:generate:desktop",
    "build": "next build",
    "start": "next start",
    "start:reaper": "tsx src/reaper-daemon.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "coverage:unit": "vitest run --config vitest.unit.config.ts --coverage",
    "coverage:integration": "vitest run --config vitest.integration.config.ts --coverage",
    "coverage:badge": "node ../../scripts/update-coverage-badges.mjs",
    "coverage:refresh": "pnpm coverage && pnpm coverage:unit && pnpm coverage:integration && pnpm coverage:badge",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:real-runtime": "ARCHE_E2E_PROFILE=real-runtime playwright test",
    "prisma:generate": "prisma generate",
    "prisma:generate:desktop": "prisma generate --config=prisma.config.desktop.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "@opencode-ai/sdk": "^1.1.48",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/core": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-table": "^3.19.0",
    "@tiptap/extension-table-cell": "^3.19.0",
    "@tiptap/extension-table-header": "^3.19.0",
    "@tiptap/extension-table-row": "^3.19.0",
    "@tiptap/extension-task-item": "^3.19.0",
    "@tiptap/extension-task-list": "^3.19.0",
    "@tiptap/markdown": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "argon2": "^0.31.2",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "dockerode": "^4.0.9",
    "fflate": "^0.8.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "otpauth": "^9.4.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.18.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "dotenv": "16.6.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "playwright": "^1.59.1",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "argon2",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ],
    "overrides": {
      "tar": "7.5.7",
      "lodash": "4.17.23",
      "hono": "4.11.7"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
