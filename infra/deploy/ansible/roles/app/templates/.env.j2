# Arche environment — generated by deploy.sh
# Mode: {{ deploy_mode }}

# Domain
ARCHE_DOMAIN={{ domain }}

# Database
DATABASE_URL=postgresql://postgres:{{ postgres_password }}@postgres:5432/arche?schema=public
POSTGRES_PASSWORD={{ postgres_password }}

# Application secrets
ARCHE_SESSION_PEPPER={{ arche_session_pepper }}
ARCHE_ENCRYPTION_KEY={{ arche_encryption_key }}
ARCHE_INTERNAL_TOKEN={{ arche_internal_token }}
ARCHE_CONNECTOR_OAUTH_STATE_SECRET={{ arche_connector_oauth_state_secret }}

# Gateway
ARCHE_GATEWAY_TOKEN_SECRET={{ arche_gateway_token_secret }}
ARCHE_GATEWAY_TOKEN_TTL_SECONDS={{ arche_gateway_token_ttl_seconds }}
ARCHE_GATEWAY_BASE_URL={{ arche_gateway_base_url }}

# Cookies
ARCHE_COOKIE_SECURE={{ 'true' if deploy_mode == 'remote' else 'false' }}

# Seed admin
ARCHE_SEED_ADMIN_EMAIL={{ arche_seed_admin_email }}
ARCHE_SEED_ADMIN_PASSWORD={{ arche_seed_admin_password }}
ARCHE_SEED_ADMIN_SLUG={{ arche_seed_admin_slug }}
{% if arche_seed_test_email is defined and arche_seed_test_email and arche_seed_test_slug is defined and arche_seed_test_slug %}
ARCHE_SEED_TEST_EMAIL={{ arche_seed_test_email }}
ARCHE_SEED_TEST_SLUG={{ arche_seed_test_slug }}
{% endif %}

# Spawner
CONTAINER_PROXY_HOST=docker-socket-proxy
CONTAINER_PROXY_PORT=2375
OPENCODE_IMAGE={{ opencode_image }}
OPENCODE_NETWORK=arche-internal

# Knowledge Base (content + config)
KB_CONTENT_HOST_PATH={{ kb_content_host_path | default('/opt/arche/kb-content') }}
KB_CONFIG_HOST_PATH={{ kb_config_host_path | default('/opt/arche/kb-config') }}

# User Data Persistence
ARCHE_USERS_PATH={{ users_path | default('/opt/arche/users') }}
