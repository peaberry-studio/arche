# Arche environment — generated by deploy.sh
# Mode: {{ deploy_mode }}

# Domain
ARCHE_DOMAIN={{ domain }}

# Release metadata
ARCHE_RELEASE_VERSION={{ web_version }}

# Database
DATABASE_URL=postgresql://postgres:{{ postgres_password }}@postgres:5432/arche?schema=public
POSTGRES_PASSWORD={{ postgres_password }}

# Application secrets
ARCHE_SESSION_PEPPER={{ arche_session_pepper }}
ARCHE_ENCRYPTION_KEY={{ arche_encryption_key }}
ARCHE_INTERNAL_TOKEN={{ arche_internal_token }}
ARCHE_CONNECTOR_OAUTH_STATE_SECRET={{ arche_connector_oauth_state_secret }}

# Gateway
ARCHE_GATEWAY_TOKEN_SECRET={{ arche_gateway_token_secret }}
ARCHE_GATEWAY_TOKEN_TTL_SECONDS={{ arche_gateway_token_ttl_seconds }}
ARCHE_GATEWAY_BASE_URL={{ arche_gateway_base_url }}
ARCHE_PUBLIC_BASE_URL={{ arche_public_base_url }}
ARCHE_SESSION_TTL_DAYS={{ arche_session_ttl_days }}

# Connector gateway
ARCHE_CONNECTOR_GATEWAY_BASE_URL={{ arche_connector_gateway_base_url }}
ARCHE_CONNECTOR_GATEWAY_TOKEN_SECRET={{ arche_connector_gateway_token_secret }}

# Connector OAuth/MCP overrides
ARCHE_CONNECTOR_OAUTH_STATE_TTL_SECONDS={{ arche_connector_oauth_state_ttl_seconds }}
ARCHE_CONNECTOR_OAUTH_MAX_AUTHORIZE_URL_LENGTH={{ arche_connector_oauth_max_authorize_url_length }}
ARCHE_CONNECTOR_LINEAR_MCP_URL={{ arche_connector_linear_mcp_url }}
ARCHE_CONNECTOR_NOTION_MCP_URL={{ arche_connector_notion_mcp_url }}
ARCHE_CONNECTOR_LINEAR_SCOPE={{ arche_connector_linear_scope }}
ARCHE_CONNECTOR_NOTION_SCOPE={{ arche_connector_notion_scope }}
ARCHE_CONNECTOR_NOTION_CLIENT_ID={{ arche_connector_notion_client_id }}
ARCHE_CONNECTOR_NOTION_CLIENT_SECRET={{ arche_connector_notion_client_secret }}
ARCHE_CONNECTOR_GOOGLE_CLIENT_ID={{ arche_connector_google_client_id }}
ARCHE_CONNECTOR_GOOGLE_CLIENT_SECRET={{ arche_connector_google_client_secret }}
ARCHE_CONNECTOR_GOOGLE_GMAIL_MCP_URL={{ arche_connector_google_gmail_mcp_url }}
ARCHE_CONNECTOR_GOOGLE_DRIVE_MCP_URL={{ arche_connector_google_drive_mcp_url }}
ARCHE_CONNECTOR_GOOGLE_CALENDAR_MCP_URL={{ arche_connector_google_calendar_mcp_url }}
ARCHE_CONNECTOR_GOOGLE_CHAT_MCP_URL={{ arche_connector_google_chat_mcp_url }}
ARCHE_CONNECTOR_GOOGLE_PEOPLE_MCP_URL={{ arche_connector_google_people_mcp_url }}
ARCHE_CONNECTOR_META_ADS_GRAPH_API_VERSION={{ arche_connector_meta_ads_graph_api_version }}

# Cookies
ARCHE_COOKIE_SECURE={{ 'true' if deploy_mode == 'remote' else 'false' }}

# Seed admin
ARCHE_SEED_ADMIN_EMAIL={{ arche_seed_admin_email }}
ARCHE_SEED_ADMIN_PASSWORD={{ arche_seed_admin_password }}
ARCHE_SEED_ADMIN_SLUG={{ arche_seed_admin_slug }}
{% if arche_seed_test_email is defined and arche_seed_test_email and arche_seed_test_slug is defined and arche_seed_test_slug %}
ARCHE_SEED_TEST_EMAIL={{ arche_seed_test_email }}
ARCHE_SEED_TEST_SLUG={{ arche_seed_test_slug }}
{% endif %}

# Spawner
CONTAINER_PROXY_HOST=docker-socket-proxy
CONTAINER_PROXY_PORT=2375
OPENCODE_IMAGE={{ opencode_image }}
OPENCODE_NETWORK=arche-internal

# Knowledge Base (content + config)
KB_CONTENT_HOST_PATH={{ kb_content_host_path | default('/opt/arche/kb-content') }}
KB_CONFIG_HOST_PATH={{ kb_config_host_path | default('/opt/arche/kb-config') }}

# User Data Persistence
ARCHE_USERS_PATH={{ users_path | default('/opt/arche/users') }}
