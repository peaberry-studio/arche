# Arche Production Compose — generated by deploy.sh
# Mode: {{ deploy_mode }}
# Domain: {{ domain }}

name: arche

services:
  traefik:
    image: traefik:v3.6.7
    restart: unless-stopped
    command:
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
      - --providers.docker.endpoint=tcp://docker-socket-proxy:2375
{% if deploy_mode == 'remote' %}
      # HTTPS entrypoint
      - --entrypoints.web.address=:80
      - --entrypoints.web.http.redirections.entryPoint.to=websecure
      - --entrypoints.web.http.redirections.entryPoint.scheme=https
      - --entrypoints.websecure.address=:443
      # ACME DNS challenge
      - --certificatesResolvers.letsencrypt.acme.email={{ acme_email }}
      - --certificatesResolvers.letsencrypt.acme.storage=/letsencrypt/acme.json
      - --certificatesResolvers.letsencrypt.acme.dnsChallenge.provider={{ dns_provider }}
      - --certificatesResolvers.letsencrypt.acme.dnsChallenge.resolvers=1.1.1.1:53,8.8.8.8:53
{% else %}
      # HTTP-only (local mode)
      - --entrypoints.web.address=:80
{% endif %}
      - --api.dashboard=false
      - --log.level=INFO
    ports:
{% if deploy_mode == 'remote' %}
      - "80:80"
      - "443:443"
    volumes:
      - traefik_letsencrypt:/letsencrypt
{% else %}
      - "8080:80"
{% endif %}
{% if deploy_mode == 'remote' %}
    environment:
{% if dns_provider == 'cloudflare' %}
      CF_DNS_API_TOKEN: "${CF_DNS_API_TOKEN}"
{% elif dns_provider == 'route53' %}
      AWS_ACCESS_KEY_ID: "${AWS_ACCESS_KEY_ID}"
      AWS_SECRET_ACCESS_KEY: "${AWS_SECRET_ACCESS_KEY}"
{% elif dns_provider == 'digitalocean' %}
      DO_AUTH_TOKEN: "${DO_AUTH_TOKEN}"
{% endif %}
{% endif %}
    networks:
      - default
      - arche-internal
    depends_on:
      - docker-socket-proxy

  docker-socket-proxy:
    image: tecnativa/docker-socket-proxy:0.3
    restart: unless-stopped
{% if deploy_mode == 'local' %}
    user: root
    security_opt:
      - label=disable
{% endif %}
    environment:
      CONTAINERS: 1
      NETWORKS: 1
      IMAGES: 1
      INFO: 1
      POST: 1
      VOLUMES: 1
    volumes:
      - {{ podman_socket_path }}:/var/run/docker.sock:ro
    networks:
      - arche-internal

  postgres:
    image: postgres:16
    restart: unless-stopped
    environment:
      POSTGRES_DB: arche
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD}"
    volumes:
      - arche_postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

  web:
    image: {{ image_prefix }}web:{{ web_version }}
    restart: unless-stopped
    env_file:
      - {{ env_file_name | default('.env') }}
    networks:
      - default
      - arche-internal
    depends_on:
      postgres:
        condition: service_healthy
    labels:
      - traefik.enable=true

{% if deploy_mode == 'remote' %}
      # Base router (no forwardAuth — login and bootstrap)
      - traefik.http.routers.arche-base.rule=Host(`{{ domain }}`)
      - traefik.http.routers.arche-base.entrypoints=websecure
      - traefik.http.routers.arche-base.tls=true
      - traefik.http.routers.arche-base.tls.certresolver=letsencrypt
      - "traefik.http.routers.arche-base.tls.domains[0].main={{ domain }}"
      - "traefik.http.routers.arche-base.tls.domains[0].sans=*.{{ domain }}"
      - traefik.http.routers.arche-base.service=arche-web

      # User subdomain router (with forwardAuth)
      - "traefik.http.routers.arche-user.rule=HostRegexp(`u-[a-z0-9-]+\\.{{ domain }}`)"
      - traefik.http.routers.arche-user.entrypoints=websecure
      - traefik.http.routers.arche-user.tls=true
      - traefik.http.routers.arche-user.tls.certresolver=letsencrypt
      - traefik.http.routers.arche-user.service=arche-web
      - traefik.http.routers.arche-user.middlewares=arche-forwardauth
{% else %}
      # Base router (no forwardAuth — login and bootstrap)
      - traefik.http.routers.arche-base.rule=Host(`{{ domain }}`)
      - traefik.http.routers.arche-base.entrypoints=web
      - traefik.http.routers.arche-base.service=arche-web

      # User subdomain router (with forwardAuth)
      - "traefik.http.routers.arche-user.rule=HostRegexp(`u-[a-z0-9-]+\\.{{ domain }}`)"
      - traefik.http.routers.arche-user.entrypoints=web
      - traefik.http.routers.arche-user.service=arche-web
      - traefik.http.routers.arche-user.middlewares=arche-forwardauth
{% endif %}

      - traefik.http.services.arche-web.loadbalancer.server.port=3000

      - traefik.http.middlewares.arche-forwardauth.forwardauth.address=http://web:3000/auth/traefik
      - traefik.http.middlewares.arche-forwardauth.forwardauth.trustForwardHeader=true

networks:
  default:
  arche-internal:
    name: arche-internal
    external: true

volumes:
  arche_postgres:
{% if deploy_mode == 'remote' %}
  traefik_letsencrypt:
{% endif %}
