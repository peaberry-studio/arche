# Arche Production Compose — generated by deploy.sh
# Mode: {{ deploy_mode }}
# Domain: {{ domain }}

name: arche

services:
  traefik:
    image: docker.io/traefik:v3.6.7
    restart: unless-stopped
    command:
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
      - --providers.docker.endpoint=tcp://docker-socket-proxy:2375
{% if deploy_mode == 'remote' %}
      # HTTPS entrypoint
      - --entrypoints.web.address=:80
      - --entrypoints.web.http.redirections.entryPoint.to=websecure
      - --entrypoints.web.http.redirections.entryPoint.scheme=https
      - --entrypoints.websecure.address=:443
      # ACME HTTP challenge (no DNS provider needed)
      - --certificatesResolvers.letsencrypt.acme.email={{ acme_email }}
      - --certificatesResolvers.letsencrypt.acme.storage=/letsencrypt/acme.json
      - --certificatesResolvers.letsencrypt.acme.httpChallenge.entryPoint=web
{% else %}
      # HTTP-only (local-dev mode)
      - --entrypoints.web.address=:80
{% endif %}
{% if deploy_mode == 'local-dev' %}
      - --api.dashboard=true
      - --api.insecure=true
{% else %}
      - --api.dashboard=false
{% endif %}
      - --log.level=INFO
    ports:
{% if deploy_mode == 'remote' %}
      - "80:80"
      - "443:443"
    volumes:
      - traefik_letsencrypt:/letsencrypt
{% elif deploy_mode == 'local-dev' %}
      - "8080:80"
      - "8081:8080"
{% endif %}
    networks:
      - default
      - arche-internal
    depends_on:
      - docker-socket-proxy
  
  docker-socket-proxy:
    image: ghcr.io/tecnativa/docker-socket-proxy:latest
    restart: unless-stopped
{% if deploy_mode == 'local-dev' %}
    user: root
    security_opt:
      - label=disable
{% endif %}
    environment:
      CONTAINERS: 1
      NETWORKS: 1
      IMAGES: 1
      INFO: 1
      POST: 1
      VOLUMES: 1
    volumes:
      - {{ podman_socket_path }}:/var/run/docker.sock:ro
    networks:
      - arche-internal
    healthcheck:
      test: ["CMD-SHELL", "test -S /var/run/docker.sock"]
      interval: 10s
      timeout: 5s
      retries: 5

  postgres:
    image: docker.io/postgres:16
    restart: unless-stopped
    environment:
      POSTGRES_DB: arche
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD}"
{% if deploy_mode == 'local-dev' %}
    ports:
      - "5432:5432"
{% endif %}
    volumes:
      - arche_postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

{% if deploy_mode == 'local-dev' %}
  # In local-dev mode, web is managed by compose (pnpm dev with source mounts).
  # In remote/local modes, web is managed outside compose via podman run
  # for true blue-green zero-downtime deployments.
  web:
    image: node:24-bookworm-slim
    working_dir: /app
    restart: unless-stopped
    env_file:
      - {{ env_file_name | default('.env') }}
    environment:
      ARCHE_GATEWAY_TOKEN_SECRET: "${ARCHE_GATEWAY_TOKEN_SECRET}"
      ARCHE_GATEWAY_TOKEN_TTL_SECONDS: "${ARCHE_GATEWAY_TOKEN_TTL_SECONDS}"
      ARCHE_GATEWAY_BASE_URL: "${ARCHE_GATEWAY_BASE_URL}"
    networks:
      - default
      - arche-internal
    depends_on:
      postgres:
        condition: service_healthy
    labels:
      - traefik.enable=true
      - traefik.http.routers.arche-base.rule=Host(`{{ domain }}`)
      - traefik.http.routers.arche-base.entrypoints=web
      - traefik.http.routers.arche-base.service=arche-web
      - traefik.http.services.arche-web.loadbalancer.server.port=3000
    volumes:
      - {{ repo_root }}/apps/web:/app
      - arche_web_node_modules:/app/node_modules
      - arche_pnpm_store:/pnpm/store
      - {{ users_path | default('/opt/arche/users') }}:{{ users_path | default('/opt/arche/users') }}
      - {{ kb_content_host_path | default('/opt/arche/kb-content') }}:/kb-content
      - {{ kb_config_host_path | default('/opt/arche/kb-config') }}:/kb-config
    command: sh -lc "apt-get update -y && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/* && corepack enable && pnpm config set store-dir /pnpm/store >/dev/null 2>&1 || true && pnpm install --prefer-offline --force && pnpm prisma generate && WATCHPACK_POLLING=true pnpm next dev --webpack -H 0.0.0.0 -p 3000"
{% endif %}

networks:
  default:
  arche-internal:
    name: arche-internal
    external: true

volumes:
  arche_postgres:
{% if deploy_mode == 'remote' %}
  traefik_letsencrypt:
{% endif %}
{% if deploy_mode == 'local-dev' %}
  arche_web_node_modules:
  arche_pnpm_store:
{% endif %}
