# Arche Deployer — Environment Variables
# Copy to .env and fill in values before deploying.

# GHCR (optional for public images; required for private images)
GHCR_TOKEN=ghp_...

# Database
POSTGRES_PASSWORD=change_me

# Arche app secrets (generate with: openssl rand -base64 32)
ARCHE_SESSION_PEPPER=
ARCHE_ENCRYPTION_KEY=
ARCHE_INTERNAL_TOKEN=
ARCHE_CONNECTOR_OAUTH_STATE_SECRET=

# Gateway (required in prod)
ARCHE_GATEWAY_TOKEN_SECRET=

# Gateway (optional)
ARCHE_GATEWAY_TOKEN_TTL_SECONDS=
ARCHE_GATEWAY_BASE_URL=
ARCHE_PUBLIC_BASE_URL=
ARCHE_SESSION_TTL_DAYS=7

# Connector gateway (optional; token secret falls back to ARCHE_GATEWAY_TOKEN_SECRET)
ARCHE_CONNECTOR_GATEWAY_BASE_URL=
ARCHE_CONNECTOR_GATEWAY_TOKEN_SECRET=

# Connector OAuth/MCP overrides (optional)
ARCHE_CONNECTOR_OAUTH_STATE_TTL_SECONDS=600
ARCHE_CONNECTOR_OAUTH_MAX_AUTHORIZE_URL_LENGTH=1800
ARCHE_CONNECTOR_LINEAR_MCP_URL=https://mcp.linear.app/mcp
ARCHE_CONNECTOR_NOTION_MCP_URL=https://mcp.notion.com/mcp
ARCHE_CONNECTOR_LINEAR_SCOPE=
ARCHE_CONNECTOR_NOTION_SCOPE=
ARCHE_CONNECTOR_NOTION_CLIENT_ID=
ARCHE_CONNECTOR_NOTION_CLIENT_SECRET=
ARCHE_CONNECTOR_GOOGLE_CLIENT_ID=
ARCHE_CONNECTOR_GOOGLE_CLIENT_SECRET=
ARCHE_CONNECTOR_GOOGLE_GMAIL_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1
ARCHE_CONNECTOR_GOOGLE_DRIVE_MCP_URL=https://drivemcp.googleapis.com/mcp/v1
ARCHE_CONNECTOR_GOOGLE_CALENDAR_MCP_URL=https://calendarmcp.googleapis.com/mcp/v1
ARCHE_CONNECTOR_GOOGLE_CHAT_MCP_URL=https://chatmcp.googleapis.com/mcp/v1
ARCHE_CONNECTOR_GOOGLE_PEOPLE_MCP_URL=https://people.googleapis.com/mcp/v1
ARCHE_CONNECTOR_META_ADS_GRAPH_API_VERSION=v25.0

# Seed admin
ARCHE_SEED_ADMIN_EMAIL=admin@example.com
ARCHE_SEED_ADMIN_PASSWORD=change-me
ARCHE_SEED_ADMIN_SLUG=admin

# Seed test user (optional)
ARCHE_SEED_TEST_EMAIL=peter@example.com
ARCHE_SEED_TEST_SLUG=peter

# DNS provider tokens are no longer needed.
# Deploy uses ACME HTTP challenge on port 80.

# Optional overrides
# IMAGE_PREFIX=ghcr.io/peaberry-studio/arche/
# WEB_VERSION=latest
# WEB_IMAGE=ghcr.io/peaberry-studio/arche/web:latest
# OPENCODE_IMAGE=arche-workspace:latest
# ARCHE_USERS_PATH=/opt/arche/users
# KB_CONTENT_HOST_PATH=/opt/arche/kb-content
# KB_CONFIG_HOST_PATH=/opt/arche/kb-config
# For arm64 hosts, use the published arm64 tags explicitly:
# WEB_IMAGE=ghcr.io/peaberry-studio/arche/web:latest-arm64
# OPENCODE_IMAGE=ghcr.io/peaberry-studio/arche/workspace:latest-arm64
# For PR-image testing, for example:
# WEB_VERSION=pr-124
# WEB_IMAGE=ghcr.io/peaberry-studio/arche/web:pr-124
# OPENCODE_IMAGE=ghcr.io/peaberry-studio/arche/workspace:pr-124
# WEB_IMAGE=ghcr.io/peaberry-studio/arche/web:pr-124-arm64
# OPENCODE_IMAGE=ghcr.io/peaberry-studio/arche/workspace:pr-124-arm64

# Build images directly on the VPS (no registry pull):
# WEB_IMAGE=arche-web:latest
# OPENCODE_IMAGE=arche-workspace:latest
