# Arche Deployer — Environment Variables
# Copy to .env and fill in values before deploying.

# GHCR (required for remote; optional for local if image already pulled)
GHCR_TOKEN=ghp_...

# Database
POSTGRES_PASSWORD=change_me

# Arche app secrets (generate with: openssl rand -base64 32)
ARCHE_SESSION_PEPPER=
ARCHE_ENCRYPTION_KEY=
ARCHE_INTERNAL_TOKEN=

# Seed admin
ARCHE_SEED_ADMIN_EMAIL=admin@example.com
ARCHE_SEED_ADMIN_PASSWORD=change-me
ARCHE_SEED_ADMIN_SLUG=admin

# DNS provider tokens (set the one matching --dns-provider)
# CF_DNS_API_TOKEN=...             # cloudflare
# AWS_ACCESS_KEY_ID=...            # route53
# AWS_SECRET_ACCESS_KEY=...        # route53
# DO_AUTH_TOKEN=...                # digitalocean

# Optional overrides
# IMAGE_PREFIX=ghcr.io/peaberry-studio/arche/
# WEB_VERSION=latest
# OPENCODE_IMAGE=ghcr.io/anomalyco/opencode:1.1.45
