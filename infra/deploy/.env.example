# Arche Deployer — Environment Variables
# Copy to .env and fill in values before deploying.

# GHCR (optional for public images; required for private images)
GHCR_TOKEN=ghp_...

# Database
POSTGRES_PASSWORD=change_me

# Arche app secrets (generate with: openssl rand -base64 32)
ARCHE_SESSION_PEPPER=
ARCHE_ENCRYPTION_KEY=
ARCHE_INTERNAL_TOKEN=
ARCHE_CONNECTOR_OAUTH_STATE_SECRET=

# Gateway (required in prod)
ARCHE_GATEWAY_TOKEN_SECRET=

# Gateway (optional)
ARCHE_GATEWAY_TOKEN_TTL_SECONDS=
ARCHE_GATEWAY_BASE_URL=

# Seed admin
ARCHE_SEED_ADMIN_EMAIL=admin@example.com
ARCHE_SEED_ADMIN_PASSWORD=change-me
ARCHE_SEED_ADMIN_SLUG=admin

# Seed test user (optional)
ARCHE_SEED_TEST_EMAIL=peter@example.com
ARCHE_SEED_TEST_SLUG=peter

# DNS provider tokens are no longer needed.
# Deploy uses ACME HTTP challenge on port 80.

# Optional overrides
# IMAGE_PREFIX=ghcr.io/peaberry-studio/arche/
# WEB_VERSION=latest
# WEB_IMAGE=ghcr.io/peaberry-studio/arche/web:latest
# OPENCODE_IMAGE=arche-workspace:latest
# For PR-image testing, for example:
# WEB_VERSION=pr-124
# WEB_IMAGE=ghcr.io/peaberry-studio/arche/web:pr-124
# OPENCODE_IMAGE=ghcr.io/peaberry-studio/arche/workspace:pr-124

# Build images directly on the VPS (no registry pull):
# WEB_IMAGE=arche-web:latest
# OPENCODE_IMAGE=arche-workspace:latest
