# Arche — Coolify Environment Variables
# Configure these in Coolify's UI or copy to .env

# =============================================================================
# REQUIRED — Domain
# =============================================================================
ARCHE_DOMAIN=arche.example.com

# =============================================================================
# REQUIRED — Database
# =============================================================================
# For separate resource setup: use the connection string from Coolify's DB resource
# For compose setup: uses SERVICE_PASSWORD_POSTGRES (auto-generated by Coolify)
# DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/arche?schema=public

# =============================================================================
# REQUIRED — Secrets (generate each with: openssl rand -base64 32)
# =============================================================================
ARCHE_SESSION_PEPPER=
ARCHE_ENCRYPTION_KEY=
ARCHE_INTERNAL_TOKEN=
ARCHE_GATEWAY_TOKEN_SECRET=
ARCHE_CONNECTOR_OAUTH_STATE_SECRET=

# =============================================================================
# REQUIRED — Initial Admin Account
# =============================================================================
ARCHE_SEED_ADMIN_EMAIL=admin@example.com
ARCHE_SEED_ADMIN_PASSWORD=
ARCHE_SEED_ADMIN_SLUG=admin

# =============================================================================
# INTERNAL — Spawner Configuration
# =============================================================================
# These values are already set by docker-compose.yml and typically do not need
# to be configured in Coolify environment variables.
# CONTAINER_PROXY_HOST=docker-socket-proxy
# CONTAINER_PROXY_PORT=2375
# OPENCODE_NETWORK=arche_internal

# =============================================================================
# OPTIONAL — Container Configuration
# =============================================================================
# Workspace image (default: ghcr.io/peaberry-studio/arche/workspace:latest)
# OPENCODE_IMAGE=ghcr.io/peaberry-studio/arche/workspace:latest

# =============================================================================
# OPTIONAL — Gateway Configuration
# =============================================================================
# ARCHE_GATEWAY_TOKEN_TTL_SECONDS=86400
# ARCHE_GATEWAY_BASE_URL=http://web:3000
# ARCHE_PUBLIC_BASE_URL=https://arche.example.com
# ARCHE_SESSION_TTL_DAYS=7
# ARCHE_CONNECTOR_GATEWAY_BASE_URL=http://web:3000/api/internal/mcp/connectors
# ARCHE_CONNECTOR_GATEWAY_TOKEN_SECRET=

# =============================================================================
# OPTIONAL — Connector OAuth/MCP Overrides
# =============================================================================
# ARCHE_CONNECTOR_GOOGLE_CLIENT_ID=
# ARCHE_CONNECTOR_GOOGLE_CLIENT_SECRET=
# ARCHE_CONNECTOR_GOOGLE_GMAIL_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1
# ARCHE_CONNECTOR_GOOGLE_DRIVE_MCP_URL=https://drivemcp.googleapis.com/mcp/v1
# ARCHE_CONNECTOR_GOOGLE_CALENDAR_MCP_URL=https://calendarmcp.googleapis.com/mcp/v1
# ARCHE_CONNECTOR_GOOGLE_CHAT_MCP_URL=https://chatmcp.googleapis.com/mcp/v1
# ARCHE_CONNECTOR_GOOGLE_PEOPLE_MCP_URL=https://people.googleapis.com/mcp/v1
# ARCHE_CONNECTOR_META_ADS_GRAPH_API_VERSION=v25.0

# =============================================================================
# OPTIONAL — Knowledge Base
# =============================================================================
# Host paths to bare repos used by kickstart/runtime (must exist on the VPS)
# KB_CONTENT_HOST_PATH=/opt/arche/kb-content
# KB_CONFIG_HOST_PATH=/opt/arche/kb-config
# ARCHE_USERS_PATH=/opt/arche/users

# =============================================================================
# OPTIONAL — Cookie Settings
# =============================================================================
# Set to false only for local development without HTTPS
# ARCHE_COOKIE_SECURE=true
