# =============================================================================
# Arche VPS Deployment - Environment Variables
# =============================================================================
# COPY THIS FILE: cp .env.vps.template .env
# THEN: Edit the values marked with [MANUAL] below
# SECURITY: Never commit this file to git! It should be in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# DEPLOYMENT TARGET (Remote VPS)
# -----------------------------------------------------------------------------
# This tells the deploy scripts to configure for remote VPS with TLS
DEPLOY_MODE=remote

# Your production domain (must point to your VPS IP before running deploy)
# [MANUAL] Change this to your actual domain
ARCHE_DOMAIN=arche.example.com

# Your email for Let's Encrypt SSL certificates
# [MANUAL] Change this to your email
ACME_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# PostgreSQL password - generate a strong password
# [MANUAL] Change to a secure password (min 20 chars recommended)
POSTGRES_PASSWORD=change-me-to-a-secure-password-min-20-chars

# -----------------------------------------------------------------------------
# APPLICATION SECRETS
# -----------------------------------------------------------------------------
# Generate these with: openssl rand -base64 32
# [MANUAL] Generate unique values for each secret below

# Session pepper - used for session token hashing
ARCHE_SESSION_PEPPER=generate-with-openssl-rand-base64-32

# Encryption key - used for encrypting sensitive data (must be base64, 32 bytes)
ARCHE_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# Internal API token - used for inter-service communication
ARCHE_INTERNAL_TOKEN=generate-with-openssl-rand-base64-32

# Gateway token secret - used for signing workspace authentication tokens
ARCHE_GATEWAY_TOKEN_SECRET=generate-with-openssl-rand-base64-32

# Gateway token TTL (optional, defaults to 3600 seconds)
# ARCHE_GATEWAY_TOKEN_TTL_SECONDS=3600

# Gateway base URL (optional, defaults to internal container network)
# ARCHE_GATEWAY_BASE_URL=http://docker-socket-proxy:2375

# -----------------------------------------------------------------------------
# GITHUB CONTAINER REGISTRY (GHCR)
# -----------------------------------------------------------------------------
# Token for pulling images from GitHub Container Registry
# Create at: https://github.com/settings/tokens
# Required scopes: read:packages
# [MANUAL] Add your GitHub personal access token
GHCR_TOKEN=ghp_your-github-token-here

# Image prefix (usually don't change unless using custom registry)
IMAGE_PREFIX=ghcr.io/peaberry-studio/arche/

# Web image version/tag (use 'latest' or specific commit SHA)
WEB_VERSION=latest

# -----------------------------------------------------------------------------
# SEED ADMIN USER
# -----------------------------------------------------------------------------
# These create the initial admin user on first deployment
# [MANUAL] Change these to your desired admin credentials
ARCHE_SEED_ADMIN_EMAIL=admin@example.com
ARCHE_SEED_ADMIN_PASSWORD=change-me-to-a-secure-password
ARCHE_SEED_ADMIN_SLUG=admin

# Optional: Create a test user (can be left empty)
# ARCHE_SEED_TEST_EMAIL=peter@example.com
# ARCHE_SEED_TEST_SLUG=peter

# -----------------------------------------------------------------------------
# OPTIONAL: PATHS
# -----------------------------------------------------------------------------
# Where to store user data on the VPS host
# Default is fine for most deployments
ARCHE_USERS_PATH=/opt/arche/users

# Knowledge Base paths (only needed if using KB features)
# KB_CONTENT_HOST_PATH=/opt/arche/kb-content
# KB_CONFIG_HOST_PATH=/opt/arche/kb-config

# =============================================================================
# QUICK SETUP CHECKLIST
# =============================================================================
# [ ] 1. Copy this file: cp .env.vps.template .env
# [ ] 2. Set ARCHE_DOMAIN to your domain
# [ ] 3. Set ACME_EMAIL to your email
# [ ] 4. Change POSTGRES_PASSWORD to a secure password
# [ ] 5. Generate and set ARCHE_SESSION_PEPPER (openssl rand -base64 32)
# [ ] 6. Generate and set ARCHE_ENCRYPTION_KEY (openssl rand -base64 32)
# [ ] 7. Generate and set ARCHE_INTERNAL_TOKEN (openssl rand -base64 32)
# [ ] 8. Generate and set ARCHE_GATEWAY_TOKEN_SECRET (openssl rand -base64 32)
# [ ] 9. Set GHCR_TOKEN with your GitHub PAT
# [ ] 10. Set ARCHE_SEED_ADMIN_EMAIL and ARCHE_SEED_ADMIN_PASSWORD
# [ ] 11. Run: ./infra/deploy/deploy.sh --ip <VPS_IP> --domain arche.example.com --ssh-key ~/.ssh/id_rsa --acme-email you@example.com
#     The script will guide you through adding DNS records for your domain.
# =============================================================================
