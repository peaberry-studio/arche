# ══════════════════════════════════════════════════════════════════════════════
# CALIX PANEL — Gemfile
# ══════════════════════════════════════════════════════════════════════════════
source "https://rubygems.org"

ruby "~> 3.3.0"

# Rails (API mode friendly)
gem "rails", "~> 7.2"

# SQLite
gem "sqlite3", "~> 2.0"

# Web server
gem "puma", "~> 6.4"

# Background jobs (SQLite-backed, no Redis needed)
gem "solid_queue", "~> 0.6"

# JSON API
gem "jbuilder", "~> 2.12"

# HTTP client (for GitHub API, CF JWKS)
gem "faraday", "~> 2.10"

# JWT validation (Cloudflare Access)
gem "jwt", "~> 2.8"

# Docker API client
gem "docker-api", "~> 2.3"

# Encryption for sensitive data
gem "lockbox", "~> 1.3"
gem "blind_index", "~> 2.5"

# Timezone data
gem "tzinfo-data"

group :development, :test do
  gem "debug"
  gem "rspec-rails", "~> 6.1"
end

group :development do
  gem "rubocop-rails", require: false
end
