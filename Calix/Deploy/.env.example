# ══════════════════════════════════════════════════════════════════════════════
# CALIX CONTROL PLANE — Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y rellena los valores.
# NUNCA commitees .env con secretos reales.

# ─── Domain ───────────────────────────────────────────────────────────────────
# Dominio base para el panel y sesiones de usuario
CALIX_DOMAIN=calix.calisteniapp.com
CALIX_SCHEME=https
CALIX_USER_SUBDOMAIN_PREFIX=u-

# ─── Data paths (host) ────────────────────────────────────────────────────────
# Directorios en el host para persistencia
CALIX_PANEL_DATA_ROOT=/var/lib/calix/panel
CALIX_USER_DATA_ROOT=/var/lib/calix/users

# ─── Cloudflare ───────────────────────────────────────────────────────────────
# Token del tunnel (Zero Trust → Networks → Tunnels → Tu tunnel → Token)
CLOUDFLARED_TOKEN=

# Audience IDs de las Access Apps (CSV, sin espacios)
# Zero Trust → Access → Applications → Tu app → Overview → Application Audience (AUD) Tag
# Necesitas el aud del panel Y el de sessions (wildcard)
CF_ACCESS_AUDS=

# ─── GitHub filtering ─────────────────────────────────────────────────────────
# Organizaciones GitHub cuyos repos se mostrarán (CSV)
ALLOWED_GH_ORGS=calisteniapp

# Repos específicos permitidos (opcional, CSV formato owner/repo)
# Si está vacío, se muestran todos los repos de ALLOWED_GH_ORGS
ALLOWED_GH_REPOS=

# ─── Rails ────────────────────────────────────────────────────────────────────
RAILS_ENV=production

# Generar con: openssl rand -hex 32
# O en Rails: rails secret
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# ─── Instance lifecycle ───────────────────────────────────────────────────────
# Minutos de inactividad antes de parar una instancia
INSTANCE_IDLE_MINUTES=30

# TTL máximo en horas (opcional, vacío = sin límite)
INSTANCE_MAX_TTL_HOURS=

# ─── Traefik ──────────────────────────────────────────────────────────────────
# Habilitar dashboard de Traefik (solo para debug, no en producción)
TRAEFIK_API_INSECURE=false

# ─── Logging ──────────────────────────────────────────────────────────────────
# Nivel de log para el panel Rails
RAILS_LOG_LEVEL=info
