{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arche",
  "version": "0.1.0",
  "identifier": "com.arche.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Arche Desktop",
        "width": 1240,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../runtime"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
